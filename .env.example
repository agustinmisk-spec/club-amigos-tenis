# Copiá este archivo como ".env" y completá los valores.

# Cadena de conexión de PostgreSQL (de Neon, Supabase o Render).
# Si la dejás vacía, la app usa un archivo local (data/db.json) -> ideal para probar sin nube.
DATABASE_URL=

# Clave secreta para firmar las sesiones (login). Poné un texto largo y aleatorio.
# Podés generar uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Puerto (Render/Railway lo asignan solos; en local podés dejar 3000)
PORT=3000
